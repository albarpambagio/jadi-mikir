    "stem": "What is the value of x in 5x - 3 = 2x + 9?",
    "choices": [
      { "id": "a", "text": "x = 4", "isCorrect": true },
      { "id": "b", "text": "x = 3", "isCorrect": false },
      { "id": "c", "text": "x = 6", "isCorrect": false },
      { "id": "d", "text": "x = 5", "isCorrect": false }
    ],
    "explanation": "5x - 3 = 2x + 9 → 5x - 2x = 9 + 3 → 3x = 12 → x = 4",
    "difficulty": "medium",
    "tags": ["equations", "variables"]
  },
  {
    "id": "ma-005",
    "topicId": "math-algebra",
    "stem": "If 2(x + 3) = 4x - 6, what is x?",
    "choices": [
      { "id": "a", "text": "x = 6", "isCorrect": true },
      { "id": "b", "text": "x = 3", "isCorrect": false },
      { "id": "c", "text": "x = 4", "isCorrect": false },
      { "id": "d", "text": "x = 2", "isCorrect": false }
    ],
    "explanation": "2(x + 3) = 4x - 6 → 2x + 6 = 4x - 6 → 6 + 6 = 4x - 2x → 12 = 2x → x = 6",
    "difficulty": "medium",
    "tags": ["equations", "distributive"]
  }
